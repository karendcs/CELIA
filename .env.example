# ════════════════════════════════════════════════════════════════
# .env.example — Variáveis para o OpenWebUI / Docker Compose
# Copie para .env e preencha os valores ANTES de subir o ambiente.
# NUNCA comite o arquivo .env no repositório.
# ════════════════════════════════════════════════════════════════

# ── OpenWebUI ─────────────────────────────────────────────────────
MCP_API_URL=http://SEU_HOST:3333
ENABLE_OPENAI_API=True
ENABLE_WORKSPACE=True
WEBUI_AUTH=True

# ── Chave de API do MCP (secret — não expor em texto claro no docker-compose) ──
MCP_API_KEY=SUBSTITUA_PELA_CHAVE_REAL
# ════════════════════════════════════════════════════════════════
# settings.example.env — Copie para settings.env e ajuste os valores
# NUNCA comite settings.env no controle de versão
# ════════════════════════════════════════════════════════════════

# ── LLM ──────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
MODEL_NAME=llama3.2:3b-instruct-q4_0

# ── Geração ───────────────────────────────────────────────────────
MAX_TOKENS=160
NUM_CTX=1536
TEMP=0.1
TOP_P=0.9
REPEAT_PENALTY=1.1
NUM_THREADS=8
OLLAMA_CONNECT_TIMEOUT=10
OLLAMA_READ_TIMEOUT=1200

# ── Embeddings ────────────────────────────────────────────────────
USE_LOCAL_EMBEDDINGS=1
HF_EMBED_MODEL=intfloat/multilingual-e5-small
EMBED_MODEL=nomic-embed-text
EMBED_BATCH=64

# ── RAG ───────────────────────────────────────────────────────────
COLLECTION_NAME=knowledge_base_hf
KNOWLEDGE_DIR=./knowledge
VECTOR_DB_DIR=./chroma_store
TOP_K=4
MIN_SIM=0.35
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# ── Chunking ──────────────────────────────────────────────────────
CHUNK_SIZE=1200
CHUNK_OVERLAP=150

# ── App ───────────────────────────────────────────────────────────
DOCKER_MODE=0
KEEP_XLSX=3
KEEP_LOGS=3

# ── Autenticação (OBRIGATÓRIO alterar antes de produção) ──────────
UPLOADER_USER=admin
UPLOADER_PASSWORD=<senha-forte-aqui>
